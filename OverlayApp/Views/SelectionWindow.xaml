<Window x:Class="OverlayApp.Views.SelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Screen Region"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#44000000"
        Cursor="Cross"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        ResizeMode="NoResize">
    <Grid>
        <!-- Canvas to track mouse drags and draw selection frame -->
        <Canvas x:Name="SelectionCanvas" Background="Transparent" 
                MouseLeftButtonDown="Canvas_MouseLeftButtonDown" 
                MouseMove="Canvas_MouseMove" 
                MouseLeftButtonUp="Canvas_MouseLeftButtonUp">
            <!-- Custom dashed selection box -->
            <Rectangle x:Name="SelectionRectangle" 
                       Stroke="#FF00D2FF" 
                       StrokeThickness="1.5" 
                       StrokeDashArray="4 4" 
                       Fill="#1800D2FF" 
                       Visibility="Collapsed"/>
        </Canvas>
    </Grid>
</Window>

<Window x:Class="OverlayApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OverlayApp.Views"
        xmlns:models="clr-namespace:OverlayApp.Models"
        mc:Ignorable="d"
        Title="Shadow AI" 
        Icon="/shadow_ai.ico"
        Height="480" 
        Width="420"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        ShowActivated="False"
        ResizeMode="NoResize">

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <!-- Animates the border gradient angle continuously to create a premium rolling border glow -->
                    <DoubleAnimation Storyboard.TargetName="MainBorder"
                                     Storyboard.TargetProperty="BorderBrush.(Brush.RelativeTransform).(RotateTransform.Angle)"
                                     From="0" To="360" Duration="0:0:6" RepeatBehavior="Forever"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Window.Resources>
        <!-- Standard WPF Boolean to Visibility Converter -->
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Sleek ScrollBar Template -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="5"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="Bg" SnapsToDevicePixels="true">
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}" Background="Transparent" BorderThickness="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}" Background="Transparent" BorderThickness="0"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Background="#40FFFFFF" BorderThickness="0">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border CornerRadius="2.5" Background="{TemplateBinding Background}"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom Slider Template -->
        <Style x:Key="SleekSliderStyle" TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border x:Name="TrackBackground" Height="4" CornerRadius="2" Background="#25FFFFFF" VerticalAlignment="Center"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}" Height="4" VerticalAlignment="Center" Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="{Binding Tag, ElementName=MainBorder}" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}" Height="4" VerticalAlignment="Center" Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="12" Height="12" Focusable="False" Cursor="Hand">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border CornerRadius="6" Background="#FFFFFF" BorderBrush="{Binding Tag, ElementName=MainBorder}" BorderThickness="2.5" SnapsToDevicePixels="True"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom Toggle Switch Template (representing CheckBox) -->
        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#F0FFFFFF"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <BulletDecorator Background="Transparent" Cursor="Hand">
                            <BulletDecorator.Bullet>
                                <Grid VerticalAlignment="Center">
                                    <Border x:Name="Track" Width="32" Height="16" CornerRadius="8" Background="#33FFFFFF" BorderThickness="0" SnapsToDevicePixels="True"/>
                                    <Border x:Name="Thumb" Width="12" Height="12" CornerRadius="6" Background="#FFFFFF" HorizontalAlignment="Left" Margin="2" SnapsToDevicePixels="True">
                                        <Border.RenderTransform>
                                            <TranslateTransform X="0"/>
                                        </Border.RenderTransform>
                                    </Border>
                                </Grid>
                            </BulletDecorator.Bullet>
                            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </BulletDecorator>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{Binding Tag, ElementName=MainBorder}"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Thumb" 
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" 
                                                             To="16" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Thumb" 
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" 
                                                             To="0" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom ProgressBar Template -->
        <Style TargetType="ProgressBar">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid x:Name="TemplateRoot">
                            <Border CornerRadius="3" Background="{TemplateBinding Background}"/>
                            <Border x:Name="PART_Indicator" HorizontalAlignment="Left" CornerRadius="3" Background="{TemplateBinding Foreground}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Theme definitions mapping to dynamic styling triggers -->
        <Style x:Key="MainBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#ED161622"/>
            <Setter Property="BorderBrush">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <LinearGradientBrush.RelativeTransform>
                            <RotateTransform CenterX="0.5" CenterY="0.5" Angle="0"/>
                        </LinearGradientBrush.RelativeTransform>
                        <GradientStop Color="#50FFFFFF" Offset="0"/>
                        <GradientStop Color="#2000D2FF" Offset="0.5"/>
                        <GradientStop Color="#15FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Tag">
                <Setter.Value>
                    <SolidColorBrush Color="#FF00D2FF"/>
                </Setter.Value>
            </Setter>
            <Style.Resources>
                <SolidColorBrush x:Key="AccentBrush" Color="#FF00D2FF"/>
            </Style.Resources>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Theme}" Value="Neon">
                    <Setter Property="Background" Value="#F21A0A2E"/>
                    <Setter Property="BorderBrush">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <LinearGradientBrush.RelativeTransform>
                                    <RotateTransform CenterX="0.5" CenterY="0.5" Angle="0"/>
                                </LinearGradientBrush.RelativeTransform>
                                <GradientStop Color="#50FFFFFF" Offset="0"/>
                                <GradientStop Color="#20FF00A0" Offset="0.5"/>
                                <GradientStop Color="#15FFFFFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Tag">
                        <Setter.Value>
                            <SolidColorBrush Color="#FFFF00A0"/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
                <DataTrigger Binding="{Binding Theme}" Value="Emerald">
                    <Setter Property="Background" Value="#F20A1E1A"/>
                    <Setter Property="BorderBrush">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <LinearGradientBrush.RelativeTransform>
                                    <RotateTransform CenterX="0.5" CenterY="0.5" Angle="0"/>
                                </LinearGradientBrush.RelativeTransform>
                                <GradientStop Color="#50FFFFFF" Offset="0"/>
                                <GradientStop Color="#2000FFCC" Offset="0.5"/>
                                <GradientStop Color="#15FFFFFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Tag">
                        <Setter.Value>
                            <SolidColorBrush Color="#FF00FFCC"/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
                <DataTrigger Binding="{Binding Theme}" Value="Sunset">
                    <Setter Property="Background" Value="#F22C121A"/>
                    <Setter Property="BorderBrush">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <LinearGradientBrush.RelativeTransform>
                                    <RotateTransform CenterX="0.5" CenterY="0.5" Angle="0"/>
                                </LinearGradientBrush.RelativeTransform>
                                <GradientStop Color="#50FFFFFF" Offset="0"/>
                                <GradientStop Color="#20FF7700" Offset="0.5"/>
                                <GradientStop Color="#15FFFFFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Tag">
                        <Setter.Value>
                            <SolidColorBrush Color="#FFFF7700"/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Navigation tab button style -->
        <Style x:Key="TabButtonStyle" TargetType="RadioButton">
            <Setter Property="GroupName" Value="Widgets"/>
            <Setter Property="Foreground" Value="#77FFFFFF"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid Background="Transparent">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <ContentPresenter Margin="0,4,0,4" HorizontalAlignment="Center"/>
                                <Border x:Name="Indicator" Height="2" CornerRadius="1" Width="18" Background="Transparent" SnapsToDevicePixels="True"/>
                            </StackPanel>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                <Setter TargetName="Indicator" Property="Background" Value="{Binding Tag, ElementName=MainBorder}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#D0FFFFFF"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Segment control radio button style -->
        <Style x:Key="SegmentButtonStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#A0FFFFFF"/>
            <Setter Property="FontSize" Value="8.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="BgBorder" CornerRadius="4" Background="#15FFFFFF" BorderThickness="1" BorderBrush="#15FFFFFF" Padding="6,3" Margin="2,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="BgBorder" Property="Background" Value="{Binding Tag, ElementName=MainBorder}"/>
                                <Setter TargetName="BgBorder" Property="BorderBrush" Value="{Binding Tag, ElementName=MainBorder}"/>
                                <Setter Property="Foreground" Value="#000000"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BgBorder" Property="Opacity" Value="0.95"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Glassmorphic Border Container -->
    <Border x:Name="MainBorder" Style="{StaticResource MainBorderStyle}" CornerRadius="16" BorderThickness="1.2">
        <Border.Effect>
            <!-- Soft drop shadow composited by DWM to blend with windows behind -->
            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Direction="315" Opacity="0.5" Color="Black"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <!-- Row 0: Title bar / Header -->
                <RowDefinition Height="Auto"/>
                <!-- Row 1: Nav Bar -->
                <RowDefinition Height="Auto"/>
                <!-- Row 2: Content Frame -->
                <RowDefinition Height="*"/>
                <!-- Row 3: Settings Drawer -->
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar / Header -->
            <Grid Grid.Row="0" Panel.ZIndex="1000" Margin="4,2,4,4" Background="Transparent" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Icon and Title -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="6,4,0,0">
                    <Image Source="/shadow_ai.ico" Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center" Stretch="Uniform"/>
                    <TextBlock Text="SHADOW" Foreground="#88FFFFFF" FontSize="10" FontWeight="Bold"/>
                    <TextBlock Text="AI" Foreground="{Binding Tag, ElementName=MainBorder}" FontSize="10" FontWeight="Bold" Margin="4,0,0,0"/>
                </StackPanel>

                <!-- Session Countdown Timer -->
                <TextBlock Grid.Column="0" Text="{Binding SessionTimerDisplay}" Foreground="#AAFFFFFF" FontSize="9.5" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,4,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLoggedIn}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Actions (Pin, Settings, Exit) -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,2,0">
                    <!-- Pin (Interactivity Lock) -->
                    <Button x:Name="PinButton" Command="{Binding ToggleClickThroughCommand}" ToolTip="Toggle Click-Through" Background="Transparent" BorderThickness="0" Margin="0,0,4,0" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="Transparent" Padding="4">
                                                <!-- Custom Pin SVG -->
                                                <Path x:Name="Icon" Data="M16 12V4h1V2H7v2h1v8l-2 2v2h5.2v6h1.6v-6H18v-2l-2-2z" 
                                                      Fill="#66FFFFFF" Width="12" Height="12" Stretch="Uniform"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Icon" Property="Fill" Value="#BFFFFFFF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsClickThrough}" Value="True">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="Transparent" Padding="4">
                                                        <Path Data="M16 12V4h1V2H7v2h1v8l-2 2v2h5.2v6h1.6v-6H18v-2l-2-2z" 
                                                              Fill="{Binding Tag, ElementName=MainBorder}" Width="12" Height="12" Stretch="Uniform"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    
                    <!-- Settings -->
                    <Button Command="{Binding ToggleSettingsCommand}" ToolTip="Settings" Background="Transparent" BorderThickness="0" Margin="0,0,4,0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent" Padding="4">
                                    <Path x:Name="Icon" Data="M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.07-0.94l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61 l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.81c-0.04-0.24-0.24-0.41-0.48-0.41 h-3.84c-0.24,0-0.43,0.17-0.47,0.41L9.25,5.35C8.66,5.59,8.12,5.92,7.63,6.29L5.24,5.33c-0.22-0.08-0.47,0-0.59,0.22L2.74,8.87 C2.62,9.08,2.66,9.34,2.86,9.48l2.03,1.58C4.84,11.36,4.8,11.69,4.8,12s0.02,0.64,0.07,0.94l-2.03,1.58 c-0.18,0.14-0.23,0.41-0.12,0.61l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.36,2.54 c0.05,0.24,0.24,0.41,0.48,0.41h3.84c0.24,0,0.44-0.17,0.47-0.41l0.36-2.54c0.59-0.24,1.13-0.56,1.62-0.94l2.39,0.96 c0.22,0.08,0.47,0,0.59-0.22l1.92-3.32c0.12-0.22,0.07-0.47-0.12-0.61L19.14,12.94z M12,15.6c-1.98,0-3.6-1.62-3.6-3.6 s1.62-3.6,3.6-3.6s3.6,1.62,3.6,3.6S13.98,15.6,12,15.6z" 
                                          Fill="#66FFFFFF" Width="12" Height="12" Stretch="Uniform"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Icon" Property="Fill" Value="#BFFFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    
                    <!-- Close -->
                    <Button Command="{Binding CloseAppCommand}" ToolTip="Close Application" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent" Padding="4">
                                    <Path x:Name="Icon" Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" 
                                          Fill="#66FFFFFF" Width="12" Height="12" Stretch="Uniform"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Icon" Property="Fill" Value="#FFFF3B30"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Navigation Tab Bar -->
            <Grid Grid.Row="1" Margin="6,2,6,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <RadioButton Grid.Column="0" Content="NOTES" Style="{StaticResource TabButtonStyle}" 
                             IsChecked="{Binding IsNotesActive, Mode=OneWay}"
                             Command="{Binding SelectWidgetCommand}" CommandParameter="Notes"/>
                             
                <RadioButton Grid.Column="1" Content="TIMER" Style="{StaticResource TabButtonStyle}" 
                             IsChecked="{Binding IsTimerActive, Mode=OneWay}"
                             Command="{Binding SelectWidgetCommand}" CommandParameter="Timer"/>
                             
                <RadioButton Grid.Column="2" Style="{StaticResource TabButtonStyle}" 
                              IsChecked="{Binding IsTxtScanActive, Mode=OneWay}"
                              Command="{Binding SelectWidgetCommand}" CommandParameter="TxtScan">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="TXT SCAN" VerticalAlignment="Center"/>
                        <Path Data="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z" 
                              Fill="#FFFF5555" Width="9" Height="9" Stretch="Uniform" Margin="4,0,0,0" VerticalAlignment="Center">
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFeatureLocked}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                    </StackPanel>
                </RadioButton>

                <RadioButton Grid.Column="3" Style="{StaticResource TabButtonStyle}" 
                              IsChecked="{Binding IsVoiceScanActive, Mode=OneWay}"
                              Command="{Binding SelectWidgetCommand}" CommandParameter="VoiceScan">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="VOICE" VerticalAlignment="Center"/>
                        <Path Data="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z" 
                              Fill="#FFFF5555" Width="9" Height="9" Stretch="Uniform" Margin="4,0,0,0" VerticalAlignment="Center">
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFeatureLocked}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                    </StackPanel>
                </RadioButton>

                <RadioButton Grid.Column="4" Content="PROFILE" Style="{StaticResource TabButtonStyle}" 
                              IsChecked="{Binding IsProfileActive, Mode=OneWay}"
                              Command="{Binding SelectWidgetCommand}" CommandParameter="Profile"/>
            </Grid>

            <!-- Content Area -->
            <Grid Grid.Row="2" Margin="6,2,6,8">
                
                <!-- NOTES WIDGET -->
                <Grid Visibility="{Binding IsNotesActive, Converter={StaticResource BoolToVis}}">
                    <Border Background="#11FFFFFF" CornerRadius="6" Padding="6">
                        <TextBox Text="{Binding NotesText, UpdateSourceTrigger=PropertyChanged}" 
                                 Background="Transparent" BorderThickness="0" Foreground="#EFFFFFFF" 
                                 AcceptsReturn="True" AcceptsTab="True" TextWrapping="Wrap" 
                                 VerticalScrollBarVisibility="Auto" FontSize="{Binding AppFontSize}"
                                 SelectionBrush="{Binding Tag, ElementName=MainBorder}" CaretBrush="#FFFFFF"/>
                    </Border>
                </Grid>


                <!-- PRESENTATION TIMER WIDGET -->
                <Grid Visibility="{Binding IsTimerActive, Converter={StaticResource BoolToVis}}">
                    <Border Background="#11FFFFFF" CornerRadius="6" Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Timer Display -->
                            <TextBlock Text="{Binding TimerDisplay}" FontSize="36" FontFamily="Consolas" FontWeight="Light" 
                                       Foreground="#FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            
                            <!-- Timer Buttons -->
                            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,4">
                                <!-- Start/Pause Button -->
                                <Button Command="{Binding TimerStartPauseCommand}" Margin="0,0,12,0" Cursor="Hand" Width="80" Height="28">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border CornerRadius="14" Background="{Binding Tag, ElementName=MainBorder}" Padding="8,4">
                                                            <TextBlock x:Name="BtnText" Text="START" Foreground="#000000" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Opacity" Value="0.95"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTimerRunning}" Value="True">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border CornerRadius="14" Background="#33FFFFFF" BorderBrush="{Binding Tag, ElementName=MainBorder}" BorderThickness="1" Padding="8,4">
                                                                    <TextBlock Text="PAUSE" Foreground="#FFFFFF" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                
                                <!-- Reset Button -->
                                <Button Command="{Binding TimerResetCommand}" Cursor="Hand" Width="80" Height="28">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border CornerRadius="14" Background="#18FFFFFF" BorderBrush="#33FFFFFF" BorderThickness="1" Padding="8,4">
                                                <TextBlock Text="RESET" Foreground="#E0FFFFFF" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#25FFFFFF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- TXT SCAN WIDGET -->
                <Grid Visibility="{Binding IsTxtScanActive, Converter={StaticResource BoolToVis}}">
                    <Border Background="#11FFFFFF" CornerRadius="6" Padding="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/> <!-- Row 0: Option Toggles -->
                                <RowDefinition Height="Auto"/> <!-- Row 1: Scan Buttons -->
                                <RowDefinition Height="*"/>    <!-- Row 2: Response Area -->
                                <RowDefinition Height="Auto"/> <!-- Row 3: Follow-up Chat Box -->
                                <RowDefinition Height="Auto"/> <!-- Row 4: Loader ProgressBar -->
                            </Grid.RowDefinitions>

                             <!-- Option Toggles (Scan Type) -->
                             <Grid Grid.Row="0" Margin="0,0,0,8">
                                 <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                     <TextBlock Text="SCAN TYPE:" VerticalAlignment="Center" Foreground="#88FFFFFF" FontSize="8.5" FontWeight="Bold" Margin="0,0,4,0"/>
                                     <RadioButton Content="NORMAL SCAN" Style="{StaticResource SegmentButtonStyle}" GroupName="TxtScanMode" IsChecked="{Binding IsNormalScanMode, Mode=TwoWay}"/>
                                     <RadioButton Content="MCQ SCAN" Style="{StaticResource SegmentButtonStyle}" GroupName="TxtScanMode" IsChecked="{Binding IsMcqScanMode, Mode=TwoWay}"/>
                                     <RadioButton Content="CODING SCAN" Style="{StaticResource SegmentButtonStyle}" GroupName="TxtScanMode" IsChecked="{Binding IsCodingScanMode, Mode=TwoWay}"/>
                                 </StackPanel>
                             </Grid>

                             <!-- Scan Controls Row -->
                             <Grid Grid.Row="1" Margin="0,0,0,8">
                                 <Grid.ColumnDefinitions>
                                     <ColumnDefinition Width="*"/>
                                     <ColumnDefinition Width="Auto"/>
                                     <ColumnDefinition Width="Auto"/>
                                 </Grid.ColumnDefinitions>

                                 <!-- Crop Scan Button -->
                                 <Button Grid.Column="0" Command="{Binding StartScanCommand}" Cursor="Hand" Height="28" Margin="0,0,4,0">
                                     <Button.Template>
                                         <ControlTemplate TargetType="Button">
                                             <Border CornerRadius="4" Background="{Binding Tag, ElementName=MainBorder}" Padding="6,4">
                                                 <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                     <Path Data="M4 4h7V2H4c-1.1 0-2 .9-2 2v7h2V4zm6 9l-4 5h12l-3-4-2.25 3L10 13z" 
                                                           Fill="#000000" Width="11" Height="11" Stretch="Uniform" Margin="0,0,4,0"/>
                                                     <TextBlock Text="CAPTURE &amp; SCAN" Foreground="#000000" FontSize="10.5" FontWeight="Bold"/>
                                                 </StackPanel>
                                             </Border>
                                             <ControlTemplate.Triggers>
                                                 <Trigger Property="IsMouseOver" Value="True">
                                                     <Setter Property="Opacity" Value="0.95"/>
                                                 </Trigger>
                                             </ControlTemplate.Triggers>
                                         </ControlTemplate>
                                     </Button.Template>
                                 </Button>

                                 <!-- Copy Button -->
                                 <Button Grid.Column="1" Command="{Binding CopyTxtCommand}" Cursor="Hand" Height="28" Width="28" ToolTip="Copy results text" Margin="0,0,4,0">
                                     <Button.Template>
                                         <ControlTemplate TargetType="Button">
                                             <Border x:Name="CopyBorder" CornerRadius="4" Background="#18FFFFFF" BorderBrush="#33FFFFFF" BorderThickness="1" Padding="4">
                                                 <Path Data="M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12V1zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z" 
                                                       Fill="#88FFFFFF" Width="13" Height="13" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                             </Border>
                                             <ControlTemplate.Triggers>
                                                 <Trigger Property="IsMouseOver" Value="True">
                                                     <Setter TargetName="CopyBorder" Property="Background" Value="#28FFFFFF"/>
                                                 </Trigger>
                                             </ControlTemplate.Triggers>
                                         </ControlTemplate>
                                     </Button.Template>
                                 </Button>

                                 <!-- Clear/Refresh Button -->
                                 <Button Grid.Column="2" Command="{Binding ClearTxtScanCommand}" Cursor="Hand" Height="28" Width="28" ToolTip="Clear results">
                                     <Button.Template>
                                         <ControlTemplate TargetType="Button">
                                             <Border x:Name="ClearBorder" CornerRadius="4" Background="#18FFFFFF" BorderBrush="#33FFFFFF" BorderThickness="1" Padding="4">
                                                 <Path Data="M17.65 6.35A7.958 7.958 0 0 0 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08A5.99 5.99 0 0 1 12 18c-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z" 
                                                       Fill="#88FFFFFF" Width="14" Height="14" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                             </Border>
                                             <ControlTemplate.Triggers>
                                                 <Trigger Property="IsMouseOver" Value="True">
                                                     <Setter TargetName="ClearBorder" Property="Background" Value="#28FFFFFF"/>
                                                 </Trigger>
                                             </ControlTemplate.Triggers>
                                         </ControlTemplate>
                                     </Button.Template>
                                 </Button>
                             </Grid>

                            <!-- Response Area -->
                            <Border Grid.Row="2" Background="#11FFFFFF" CornerRadius="4" Padding="6">
                                <ScrollViewer x:Name="TxtScanScrollViewer" VerticalScrollBarVisibility="Auto" CanContentScroll="False">
                                    <StackPanel>
                                        <!-- Captured Image Preview (if available) -->
                                        <Border BorderBrush="#33FFFFFF" BorderThickness="1" CornerRadius="4" Width="100" Height="60" HorizontalAlignment="Left" Margin="0,0,0,8" ClipToBounds="True">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding CapturedPreview}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Image Source="{Binding CapturedPreview}" Stretch="UniformToFill"/>
                                        </Border>
                                        
                                        <!-- Scan Results Text -->
                                        <TextBlock local:TextBlockHelper.FormattedText="{Binding ScanResponseText}" Foreground="#E0FFFFFF" FontSize="{Binding AppFontSize}" TextWrapping="Wrap" Background="Transparent"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>

                            <!-- Preset Follow-up Buttons for Text Scan -->
                            <ItemsControl Grid.Row="3" Margin="0,6,0,0" 
                                          ItemsSource="{Binding PresetFollowUps}" 
                                          Visibility="{Binding IsFollowUpVisible, Converter={StaticResource BoolToVis}}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding}" 
                                                Margin="2,2" 
                                                Padding="7,3" 
                                                FontSize="10" 
                                                FontWeight="Medium"
                                                Cursor="Hand"
                                                Command="{Binding DataContext.AskFollowUpCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="#1AFFFFFF"/>
                                                    <Setter Property="Foreground" Value="#DDFFFFFF"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}" BorderBrush="#33FFFFFF" BorderThickness="1">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#44FFFFFF"/>
                                                            <Setter Property="Foreground" Value="#FFFFFFFF"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Loader Spinner Bar -->
                            <ProgressBar Grid.Row="4" Height="4" IsIndeterminate="True" Background="#11FFFFFF" Foreground="{Binding Tag, ElementName=MainBorder}" Margin="0,6,0,0" Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- VOICE SCAN WIDGET -->
                <Grid Visibility="{Binding IsVoiceScanActive, Converter={StaticResource BoolToVis}}">
                    <Border Background="#11FFFFFF" CornerRadius="6" Padding="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/> <!-- Row 0: Option Toggles -->
                                <RowDefinition Height="Auto"/> <!-- Row 1: Record Control -->
                                <RowDefinition Height="*"/>    <!-- Row 2: Response Area -->
                                <RowDefinition Height="Auto"/> <!-- Row 3: Follow-up Chat Box -->
                                <RowDefinition Height="Auto"/> <!-- Row 4: Loader ProgressBar -->
                            </Grid.RowDefinitions>

                            <!-- Option Toggles (Audio Source and Live Mode) -->
                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Left Column: Audio Source -->
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="SOURCE:" VerticalAlignment="Center" Foreground="#88FFFFFF" FontSize="8.5" FontWeight="Bold" Margin="0,0,4,0"/>
                                    <RadioButton Content="MIC" Style="{StaticResource SegmentButtonStyle}" GroupName="VoiceSource" IsChecked="{Binding IsMicrophoneSource, Mode=TwoWay}"/>
                                    <RadioButton Content="SYSTEM" Style="{StaticResource SegmentButtonStyle}" GroupName="VoiceSource" IsChecked="{Binding IsSystemAudioSource, Mode=TwoWay}"/>
                                </StackPanel>

                                <!-- Right Column: Recording Mode -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <TextBlock Text="MODE:" VerticalAlignment="Center" Foreground="#88FFFFFF" FontSize="8.5" FontWeight="Bold" Margin="0,0,4,0"/>
                                    <RadioButton Content="MANUAL" Style="{StaticResource SegmentButtonStyle}" GroupName="VoiceMode" IsChecked="{Binding IsManualMode, Mode=TwoWay}"/>
                                    <RadioButton Content="LIVE AUTO" Style="{StaticResource SegmentButtonStyle}" GroupName="VoiceMode" IsChecked="{Binding IsLiveMode, Mode=TwoWay}"/>
                                </StackPanel>
                            </Grid>

                             <!-- Voice Controls Row -->
                             <Grid Grid.Row="1" Margin="0,0,0,8">
                                 <Grid.ColumnDefinitions>
                                     <ColumnDefinition Width="*"/>
                                     <ColumnDefinition Width="Auto"/>
                                     <ColumnDefinition Width="Auto"/>
                                 </Grid.ColumnDefinitions>

                                 <!-- Voice Record Button -->
                                 <Button Grid.Column="0" Command="{Binding ToggleVoiceCommand}" Cursor="Hand" Height="28" Margin="0,0,4,0">
                                     <Button.Style>
                                         <Style TargetType="Button">
                                             <Setter Property="Template">
                                                 <Setter.Value>
                                                     <ControlTemplate TargetType="Button">
                                                         <Border CornerRadius="4" Background="#20FFFFFF" BorderBrush="{Binding Tag, ElementName=MainBorder}" BorderThickness="1" Padding="6,4">
                                                             <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                 <Path Data="M12 14c1.66 0 3-1.34 3-3V5c0-1.66-1.34-3-3-3S9 3.34 9 5v6c0 1.66 1.34 3 3 3zm5.3-3c0 3-2.54 5.1-5.3 5.1S6.7 14 6.7 11H5c0 3.41 2.72 6.23 6 6.72V21h2v-3.28c3.28-.48 6-3.3 6-6.72h-1.7z" 
                                                                       Fill="#FFFFFF" Width="11" Height="11" Stretch="Uniform" Margin="0,0,4,0"/>
                                                                 <TextBlock Text="{Binding VoiceBtnText}" Foreground="#FFFFFF" FontSize="10.5" FontWeight="Bold"/>
                                                             </StackPanel>
                                                         </Border>
                                                         <ControlTemplate.Triggers>
                                                             <Trigger Property="IsMouseOver" Value="True">
                                                                 <Setter Property="Opacity" Value="0.9"/>
                                                             </Trigger>
                                                         </ControlTemplate.Triggers>
                                                     </ControlTemplate>
                                                 </Setter.Value>
                                             </Setter>
                                             <Style.Triggers>
                                                 <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                                     <Setter Property="Template">
                                                         <Setter.Value>
                                                             <ControlTemplate TargetType="Button">
                                                                 <Border CornerRadius="4" Background="#FFFF453A" Padding="6,4">
                                                                     <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                         <Path Data="M6 19h12V5H6v14z" 
                                                                               Fill="#000000" Width="11" Height="11" Stretch="Uniform" Margin="0,0,4,0"/>
                                                                         <TextBlock Text="{Binding VoiceBtnText}" Foreground="#000000" FontSize="10.5" FontWeight="Bold"/>
                                                                     </StackPanel>
                                                                 </Border>
                                                             </ControlTemplate>
                                                         </Setter.Value>
                                                     </Setter>
                                                 </DataTrigger>
                                             </Style.Triggers>
                                         </Style>
                                     </Button.Style>
                                 </Button>

                                 <!-- Copy Button -->
                                 <Button Grid.Column="1" Command="{Binding CopyVoiceCommand}" Cursor="Hand" Height="28" Width="28" ToolTip="Copy response text" Margin="0,0,4,0">
                                     <Button.Template>
                                         <ControlTemplate TargetType="Button">
                                             <Border x:Name="VoiceCopyBorder" CornerRadius="4" Background="#18FFFFFF" BorderBrush="#33FFFFFF" BorderThickness="1" Padding="4">
                                                 <Path Data="M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12V1zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z" 
                                                       Fill="#88FFFFFF" Width="13" Height="13" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                             </Border>
                                             <ControlTemplate.Triggers>
                                                 <Trigger Property="IsMouseOver" Value="True">
                                                     <Setter TargetName="VoiceCopyBorder" Property="Background" Value="#28FFFFFF"/>
                                                 </Trigger>
                                             </ControlTemplate.Triggers>
                                         </ControlTemplate>
                                     </Button.Template>
                                 </Button>

                                 <!-- Clear/Refresh Button -->
                                 <Button Grid.Column="2" Command="{Binding ClearVoiceScanCommand}" Cursor="Hand" Height="28" Width="28" ToolTip="Clear results">
                                     <Button.Template>
                                         <ControlTemplate TargetType="Button">
                                             <Border x:Name="VoiceClearBorder" CornerRadius="4" Background="#18FFFFFF" BorderBrush="#33FFFFFF" BorderThickness="1" Padding="4">
                                                 <Path Data="M17.65 6.35A7.958 7.958 0 0 0 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08A5.99 5.99 0 0 1 12 18c-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z" 
                                                       Fill="#88FFFFFF" Width="14" Height="14" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                             </Border>
                                             <ControlTemplate.Triggers>
                                                 <Trigger Property="IsMouseOver" Value="True">
                                                     <Setter TargetName="VoiceClearBorder" Property="Background" Value="#28FFFFFF"/>
                                                 </Trigger>
                                             </ControlTemplate.Triggers>
                                         </ControlTemplate>
                                     </Button.Template>
                                 </Button>
                             </Grid>

                            <!-- Voice Response Area -->
                            <Border Grid.Row="2" Background="#11FFFFFF" CornerRadius="4" Padding="6">
                                <ScrollViewer x:Name="VoiceScanScrollViewer" VerticalScrollBarVisibility="Auto" CanContentScroll="False">
                                    <TextBlock local:TextBlockHelper.FormattedText="{Binding VoiceScanResponseText}" FontSize="{Binding AppFontSize}" TextWrapping="Wrap" Background="Transparent"/>
                                </ScrollViewer>
                            </Border>

                            <!-- Follow-up Chat Input Bar -->
                            <Border Grid.Row="3" Margin="0,8,0,0" Background="#11FFFFFF" CornerRadius="4" Padding="4,2" Visibility="{Binding IsFollowUpVisible, Converter={StaticResource BoolToVis}}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Chat Input TextBox -->
                                    <TextBox Grid.Column="0" Text="{Binding FollowUpText, UpdateSourceTrigger=PropertyChanged}" 
                                             Foreground="#E0FFFFFF" FontSize="10.5" Background="Transparent" BorderThickness="0" 
                                             VerticalContentAlignment="Center" Margin="4,2" CaretBrush="#FFFFFF" SelectionBrush="{Binding Tag, ElementName=MainBorder}">
                                        <TextBox.InputBindings>
                                            <KeyBinding Key="Enter" Command="{Binding SubmitFollowUpCommand}"/>
                                        </TextBox.InputBindings>
                                    </TextBox>

                                    <!-- Follow-up Microphone Button (takes external mic only) -->
                                    <Button Grid.Column="1" Command="{Binding ToggleFollowUpVoiceCommand}" Cursor="Hand" Background="Transparent" BorderThickness="0" Margin="2,0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="Transparent" Padding="4">
                                                    <!-- Simple mic SVG -->
                                                    <Path x:Name="MicIcon" Data="M12 14c1.66 0 3-1.34 3-3V5c0-1.66-1.34-3-3-3S9 3.34 9 5v6c0 1.66 1.34 3 3 3zm5.3-3c0 3-2.54 5.1-5.3 5.1S6.7 14 6.7 11H5c0 3.41 2.72 6.23 6 6.72V21h2v-3.28c3.28-.48 6-3.3 6-6.72h-1.7z" 
                                                          Fill="{Binding FollowUpMicColor}" Width="10.5" Height="10.5" Stretch="Uniform"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <!-- Send Button -->
                                    <Button Grid.Column="2" Command="{Binding SubmitFollowUpCommand}" Cursor="Hand" Background="Transparent" BorderThickness="0" Margin="2,0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="Transparent" Padding="4">
                                                    <!-- Simple paper plane Send SVG -->
                                                    <Path x:Name="SendIcon" Data="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z" 
                                                          Fill="#88FFFFFF" Width="10.5" Height="10.5" Stretch="Uniform"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="SendIcon" Property="Fill" Value="{Binding Tag, ElementName=MainBorder}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </Border>

                            <!-- Loader Spinner Bar -->
                            <ProgressBar Grid.Row="4" Height="4" IsIndeterminate="True" Background="#11FFFFFF" Foreground="{Binding Tag, ElementName=MainBorder}" Margin="0,6,0,0" Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- PROFILE WIDGET -->
                <Grid Visibility="{Binding IsProfileActive, Converter={StaticResource BoolToVis}}">
                    <Border Background="#11FFFFFF" CornerRadius="6" Padding="14">
                        <StackPanel VerticalAlignment="Center">
                            <Border Width="36" Height="36" CornerRadius="18" Background="#2000FFCC" HorizontalAlignment="Center" Margin="0,0,0,8">
                                <TextBlock Text="👤" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="ACCOUNT PROFILE" Foreground="#FFFFFF" FontSize="12.5" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                            
                            <!-- Name Row -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Name:" Foreground="#88FFFFFF" FontSize="10.5" Width="70"/>
                                <TextBlock Grid.Column="1" Text="{Binding ProfileName}" Foreground="#00FFCC" FontSize="11" FontWeight="SemiBold"/>
                            </Grid>

                            <!-- Email Row -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Email:" Foreground="#88FFFFFF" FontSize="10.5" Width="70"/>
                                <TextBlock Grid.Column="1" Text="{Binding UserEmail}" Foreground="#FFFFFF" FontSize="11" FontWeight="SemiBold" TextWrapping="Wrap"/>
                            </Grid>

                            <!-- Groq Key Row -->
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Groq Key:" Foreground="#88FFFFFF" FontSize="10.5" Width="70"/>
                                <TextBlock Grid.Column="1" Text="{Binding MaskedGroqKey}" Foreground="#FFFFFF" FontSize="10.5" FontFamily="Consolas" FontWeight="SemiBold" TextWrapping="Wrap"/>
                            </Grid>
                            
                            <Border Height="1" Background="#20FFFFFF" Margin="0,0,0,10"/>
                            <TextBlock Text="To edit your key, please use the settings drawer or log out and log back in." Foreground="#66FFFFFF" FontSize="8.5" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <!-- Settings Drawer (Collapsible) -->
            <Grid Grid.Row="3">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSettingsOpen}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                
                <!-- Dark Overlay Divider Line -->
                <Border BorderBrush="#20FFFFFF" BorderThickness="0,1,0,0">
                    <Grid Margin="10,8,10,12">
                        <Grid.RowDefinitions>
                            <!-- Row 0: Header with Close (X) Button -->
                            <RowDefinition Height="Auto"/>
                            <!-- Row 1: Opacity Slider -->
                            <RowDefinition Height="Auto"/>
                            <!-- Row 2: Font Size Slider -->
                            <RowDefinition Height="Auto"/>
                            <!-- Row 3: Always on Top & Lock toggles -->
                            <RowDefinition Height="Auto"/>
                            <!-- Row 4: Theme choices -->
                            <RowDefinition Height="Auto"/>
                            <!-- Row 5: Groq API Key input -->
                            <RowDefinition Height="Auto"/>
                            <!-- Row 6: Click-Through Warn -->
                            <RowDefinition Height="Auto"/>
                            <!-- Row 7: Project Quotation -->
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Settings Header with Close Button -->
                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

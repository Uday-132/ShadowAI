<Window x:Class="OverlayInstaller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Overlay HUD Installer" 
        Height="320" 
        Width="480"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- Sleek Slider / ProgressBar Styling -->
        <Style TargetType="ProgressBar">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid x:Name="TemplateRoot">
                            <Border CornerRadius="3" Background="#22FFFFFF"/>
                            <Border x:Name="PART_Indicator" HorizontalAlignment="Left" CornerRadius="3" Background="#FF00D2FF"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Glassmorphic Border Container -->
    <Border CornerRadius="12" BorderThickness="1.2" Background="#F20B0914">
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#40FFFFFF" Offset="0"/>
                <GradientStop Color="#08FFFFFF" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="6" Direction="315" Opacity="0.5" Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <!-- Row 0: Custom Header -->
                <RowDefinition Height="36"/>
                <!-- Row 1: Content Area -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom Header / Title Bar -->
            <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                    <Path Data="M3 13h2v-2H3v2zm0 4h2v-2H3v2zm0-8h2V7H3v2zm4 4h14v-2H7v2zm0 4h14v-2H7v2zM7 7v2h14V7H7z" 
                          Fill="#FF00D2FF" Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0"/>
                    <TextBlock Text="OVERLAY HUD SETUP" Foreground="#88FFFFFF" FontSize="10.5" FontWeight="Bold"/>
                </StackPanel>

                <!-- Close Action -->
                <Button Grid.Column="1" Click="CloseButton_Click" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,0,10,0" VerticalAlignment="Center">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent" Padding="4">
                                <Path x:Name="Icon" Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" 
                                      Fill="#55FFFFFF" Width="11" Height="11" Stretch="Uniform"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Icon" Property="Fill" Value="#FFFF3B30"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Main Content Area -->
            <Grid Grid.Row="1" Margin="20,4,20,20">
                <!-- Screen 1: Welcome & Ready to Install -->
                <Grid x:Name="InstallScreen" Visibility="Visible">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Icon Area -->
                    <Border Grid.Column="0" Background="#10FFFFFF" CornerRadius="8" Margin="0,0,16,0" VerticalAlignment="Stretch">
                        <Grid>
                            <Path Data="M12 2L2 7l10 5 10-5-10-5z M2 17l10 5 10-5M2 12l10 5 10-5" 
                                  Fill="#FF00D2FF" Width="48" Height="48" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Right Description Panel -->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel VerticalAlignment="Top" Margin="0,8,0,0">
                            <TextBlock Text="Install Overlay HUD" Foreground="#FFFFFF" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
                            <TextBlock Text="This setup wizard will install the premium Overlay HUD widget on your desktop." 
                                       Foreground="#A09CB0" FontSize="11.5" TextWrapping="Wrap" Margin="0,0,0,12"/>
                            <TextBlock Text="• Shortcuts will be placed on Desktop &amp; Start Menu" Foreground="#A09CB0" FontSize="11" Margin="0,0,0,4"/>
                            <TextBlock Text="• Registered under Settings -> Apps for easy management" Foreground="#A09CB0" FontSize="11"/>
                        </StackPanel>

                        <!-- Install Button -->
                        <Button Grid.Row="1" Click="InstallButton_Click" Height="32" Width="140" HorizontalAlignment="Right" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border CornerRadius="16" Background="#FF00D2FF" Padding="14,4">
                                        <TextBlock Text="INSTALL HUD" Foreground="#000000" FontSize="11.5" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="0.9"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Grid>

                <!-- Screen 2: Installation Active Progress -->
                <Grid x:Name="ProgressScreen" Visibility="Collapsed" VerticalAlignment="Center" Margin="10,0">
                    <StackPanel>
                        <TextBlock x:Name="StatusText" Text="Extracting resources..." Foreground="#FFFFFF" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <ProgressBar x:Name="InstallProgressBar" Height="8" Minimum="0" Maximum="100" Value="10" Margin="0,0,0,14"/>
                        <TextBlock Text="Please wait while Overlay HUD configures your desktop shortcuts..." Foreground="#88FFFFFF" FontSize="11"/>
                    </StackPanel>
                </Grid>

                <!-- Screen 3: Installation Complete -->
                <Grid x:Name="FinishedScreen" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Checkmark Badge -->
                    <Border Grid.Column="0" Background="#10FFFFFF" CornerRadius="8" Margin="0,0,16,0" VerticalAlignment="Stretch">
                        <Grid>
                            <Path Data="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" 
                                  Fill="#FF00FFCC" Width="48" Height="48" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel VerticalAlignment="Top" Margin="0,8,0,0">
                            <TextBlock Text="Installation Completed" Foreground="#FFFFFF" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
                            <TextBlock Text="Overlay HUD has been successfully configured on your system." 
                                       Foreground="#A09CB0" FontSize="11.5" TextWrapping="Wrap" Margin="0,0,0,20"/>
                            
                            <!-- Option Checklist -->
                            <CheckBox x:Name="LaunchCheckBox" IsChecked="True" Content="Launch Overlay HUD now" Foreground="#FFFFFF" FontSize="12">
                                <CheckBox.Style>
                                    <Style TargetType="CheckBox">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="CheckBox">
                                                    <BulletDecorator Background="Transparent" Cursor="Hand">
                                                        <BulletDecorator.Bullet>
                                                            <Grid VerticalAlignment="Center">
                                                                <!-- Mock Switch -->
                                                                <Border x:Name="Track" Width="30" Height="14" CornerRadius="7" Background="#33FFFFFF" BorderThickness="0" SnapsToDevicePixels="True"/>
                                                                <Border x:Name="Thumb" Width="10" Height="10" CornerRadius="5" Background="#FFFFFF" HorizontalAlignment="Left" Margin="2" SnapsToDevicePixels="True">
                                                                    <Border.RenderTransform>
                                                                        <TranslateTransform X="0"/>
                                                                    </Border.RenderTransform>
                                                                </Border>
                                                            </Grid>
                                                        </BulletDecorator.Bullet>
                                                        <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center"/>
                                                    </BulletDecorator>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter TargetName="Track" Property="Background" Value="#FF00FFCC"/>
                                                            <Trigger.EnterActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetName="Thumb" 
                                                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" 
                                                                                         To="16" Duration="0:0:0.1"/>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </Trigger.EnterActions>
                                                            <Trigger.ExitActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetName="Thumb" 
                                                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" 
                                                                                         To="0" Duration="0:0:0.1"/>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </Trigger.ExitActions>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </CheckBox.Style>
                            </CheckBox>
                            </StackPanel>

                            <!-- Close Finish Button -->
                            <Button Grid.Row="1" Click="CloseButton_Click" Height="32" Width="120" HorizontalAlignment="Right" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border CornerRadius="16" Background="#FF00FFCC" Padding="14,4">
                                            <TextBlock Text="FINISH" Foreground="#000000" FontSize="11.5" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.9"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
    </Border>
</Window>
